{%  extends 'admin/base.html.twig' %}
{% block title %}Rendez-vous{% endblock %}
{% block content %}
<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">📅 Rendez-vous</h1>
        <a href="{{ path('admin_rendez_vous_new') }}" class="btn btn-primary">➕ Nouveau</a>
    </div>

    {%  for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    {%  endfor %}

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Élève</th>
                        <th>Mentor</th>
                        <th>Date</th>
                        <th>Statut</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {%  for item in items %}
                    <tr>
                        <td>{{ item.id }}</td>
                        <td>{{ item.idEleve.nomComplet }}</td>
                        <td>{{ item.idMentor.utilisateur.nomComplet }}</td>
                        <td>{{ item.date|date('d/m/Y H:i') }}</td>
                        <td>
                            <span class="badge bg-{{ item.statut == 'confirme' ? 'success' : (item.statut == 'annule' ? 'danger' : 'warning') }}">
                                {{ item.statut|replace({'_': ' '})|capitalize }}
                            </span>
                        </td>
                        <td class="text-center">
<a href="{{ path('admin_rendez_vous_show', {'id': item.id}) }}" class="btn btn-sm btn-info">👁️</a>
                            <a href="{{ path('admin_rendez_vous_edit', {'id': item.id}) }}" class="btn btn-sm btn-warning">✏️</a>
<form method="post" action="{{ path('admin_rendez_vous_delete', {'id': item.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Confirmer la suppression ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                                <button type="submit" class="btn btn-sm btn-danger">🗑️</button>
                            </form>
                        </td>
                    </tr>
                    {%  else %}
                    <tr><td colspan="6" class="text-center text-muted py-4">Aucun enregistrement.</td></tr>
                    {%  endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

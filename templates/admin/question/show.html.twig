{%  extends 'admin/base.html.twig' %}
{% block title %}Détail Question{% endblock %}
{% block body %}
<div
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">❓ Détail Question</h1>
        <div>
<a href="{{ path('admin_question_edit', {'id': item.id}) }}" class="btn btn-warning">✏️ Modifier</a>
            <a href="{{ path('admin_question_index') }}" class="btn btn-secondary">← Retour</a>
        </div>
    </div>
    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4">ID</dt>
                <dd class="col-sm-8">{{ item.id }}</dd>
                        <dt class="col-sm-4">Test</dt>
                        <dd class="col-sm-8">{{{ item.test.titre }}}</dd>
                        <dt class="col-sm-4">Contenu</dt>
                        <dd class="col-sm-8">{{{ item.contenu }}}</dd>

            </dl>
            <form method="post" action="{{ path('admin_question_delete', {{ 'id': item.id }}) }}"
                  onsubmit="return confirm('Supprimer cet élément ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                <button type="submit" class="btn btn-danger btn-sm">🗑️ Supprimer</button>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{%  extends 'admin/base.html.twig' %}
{% block title %}Détail Sujet de forum{% endblock %}
{% block content %}
<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">💬 Détail Sujet de forum</h1>
        <div>
<a href="{{ path('admin_forum_edit', {'id': item.id}) }}" class="btn btn-warning">✏️ Modifier</a>
            <a href="{{ path('admin_forum_index') }}" class="btn btn-secondary">← Retour</a>
        </div>
    </div>
    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4">ID</dt>
                <dd class="col-sm-8">{{ item.id }}</dd>
                        <dt class="col-sm-4">Titre</dt>
                            <dd class="col-sm-8">{{ item.titre }}</dd>

                        <dt class="col-sm-4">Filière</dt>
                        <dd class="col-sm-8">{{ item.filiere.nom }}</dd>

                        <dt class="col-sm-4">Auteur</dt>
                        <dd class="col-sm-8">{{ item.auteur.nomComplet }}</dd>

                        <dt class="col-sm-4">Contenu</dt>
                        <dd class="col-sm-8">{{ item.contenu }}</dd>


            </dl>
<form method="post" action="{{ path('admin_forum_delete', {'id': item.id}) }}"

                  onsubmit="return confirm('Supprimer cet élément ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                <button type="submit" class="btn btn-danger btn-sm">🗑️ Supprimer</button>
            </form>
        </div>
    </div>
</div>
{% endblock %}

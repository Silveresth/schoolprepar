{% extends 'admin/base.html.twig' %}
{% block title %}{{ filiere.nom }}{% endblock %}
{% block page_header %}
    <h1 class="h3 mb-3">Filière : <strong>{{ filiere.nom }}</strong></h1>
{% endblock %}
{% block body %}
<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header"><h5 class="card-title mb-0">Détails de la filière</h5></div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Nom</dt><dd class="col-sm-8">{{ filiere.nom }}</dd>
                    <dt class="col-sm-4">Établissement</dt><dd class="col-sm-8">{{ filiere.etablissement.nom }}</dd>
                    <dt class="col-sm-4">Niveau requis</dt><dd class="col-sm-8"><span class="badge bg-info">{{ filiere.niveauRequis }}</span></dd>
                    <dt class="col-sm-4">Débouchés</dt><dd class="col-sm-8">{{ filiere.debouche }}</dd>
                    <dt class="col-sm-4">Description</dt><dd class="col-sm-8">{{ filiere.description }}</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body d-flex flex-column gap-2">
                <a href="{{ path('admin_filiere_edit', {id: filiere.id}) }}" class="btn btn-warning w-100">Modifier</a>
                <form method="post" action="{{ path('admin_filiere_delete', {id: filiere.id}) }}" onsubmit="return confirm('Supprimer ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ filiere.id) }}">
                    <button type="submit" class="btn btn-danger w-100">Supprimer</button>
                </form>
                <a href="{{ path('admin_filiere_index') }}" class="btn btn-secondary w-100">Retour à la liste</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

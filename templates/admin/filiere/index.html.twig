{% extends 'admin/base.html.twig' %}

{% block title %}Filières - SchoolPrepar{% endblock %}

{% block page_header %}
    <h1 class="h3 mb-3"><strong>Filières</strong></h1>
{% endblock %}

{% block body %}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Liste des filières ({{ filieres|length }})</h5>
        <a href="#!" class="btn btn-primary" onclick="alert('Fonction CRUD à implémenter'); return false;">Nouvelle filière</a>
    </div>
    <table class="table table-hover my-0">
        <thead>
            <tr>
                <th>#</th>
                <th>Nom de la filière</th>
                <th>Domaine</th>
                <th>Établissement</th>
                <th>Durée</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for filiere in filieres %}
            <tr>
                <td>{{ loop.index }}</td>
                <td><strong>{{ filiere.nom }}</strong></td>
                <td>{{ filiere.domaine }}</td>
                <td>{{ filiere.etablissement }}</td>
                <td>{{ filiere.duree }}</td>
                <td>
                    <div class=\"btn-group\" role=\"group\">
                        <a href=\"#!\" class=\"btn btn-sm btn-success\" onclick=\"alert('Fonction Edit à implémenter'); return false;\">Modifier</a>
                        <a href=\"#!\" class=\"btn btn-sm btn-danger\" onclick=\"alert('Fonction Delete à implémenter'); return false;\">Supprimer</a>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="5" class="text-center text-muted py-4">Aucune filière pour le moment.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}

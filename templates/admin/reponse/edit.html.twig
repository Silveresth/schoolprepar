{% extends 'admin/base.html.twig' %}
{% block title %}Modifier Réponse{% endblock %}
{% block content %}
<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">✏️ Modifier Réponse</h1>
        <a href="{{ path('admin_reponse_index') }}" class="btn btn-secondary">← Retour</a>
    </div>
    <div class="card"><div class="card-body">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
        <div class="mb-3">{{ form_row(form.question) }}</div>
        <div class="mb-3">{{ form_row(form.contenu) }}</div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-warning">💾 Mettre à jour</button>
            <a href="{{ path('admin_reponse_show', {'id': item.id}) }}" class="btn btn-outline-secondary">Annuler</a>
        </div>
        {{ form_end(form) }}
    </div></div>
</div>
{% endblock %}

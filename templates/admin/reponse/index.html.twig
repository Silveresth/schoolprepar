{% extends 'admin/base.html.twig' %}
{% block title %}Réponses{% endblock %}
{% block content %}
<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">💬 Réponses</h1>
        <a href="{{ path('admin_reponse_new') }}" class="btn btn-primary">➕ Nouvelle Réponse</a>
    </div>
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    {% endfor %}
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr><th>#</th><th>Question</th><th>Aperçu réponse</th><th class="text-center">Actions</th></tr>
                </thead>
                <tbody>
                    {% for item in items %}
                    <tr>
                        <td>{{ item.id }}</td>
                        <td class="text-truncate" style="max-width:200px">{{ item.question.contenu|slice(0,60) }}...</td>
                        <td class="text-truncate" style="max-width:250px">{{ item.contenu|slice(0,80) }}...</td>
                        <td class="text-center">
                            <a href="{{ path('admin_reponse_show', {'id': item.id}) }}" class="btn btn-sm btn-info">👁️</a>
                            <a href="{{ path('admin_reponse_edit', {'id': item.id}) }}" class="btn btn-sm btn-warning">✏️</a>
                            <form method="post" action="{{ path('admin_reponse_delete', {'id': item.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Supprimer cette réponse ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                                <button type="submit" class="btn btn-sm btn-danger">🗑️</button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="4" class="text-center text-muted py-4">Aucune réponse enregistrée.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

{%  extends 'admin/base.html.twig' %}
{% block title %}Nouveau Test{% endblock %}
{% block body %}
<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">➕ Nouveau Test</h1>
        <a href="{{ path('admin_test_index') }}" class="btn btn-secondary">← Retour</a>
    </div>
    <div class="card">
        <div class="card-body">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            {%  if form.vars.errors|length > 0 %}
                <div class="alert alert-warning">Veuillez corriger les erreurs du formulaire.</div>
            {%  endif %}
            <div class="mb-3">{{ form_row(form.titre) }}</div>
            <div class="mb-3">{{ form_row(form.description) }}</div>
            <div class="mb-3">{{ form_row(form.date) }}</div>
            <div class="mb-3">{{ form_row(form.duree) }}</div>
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
                <a href="{{ path('admin_test_index') }}" class="btn btn-outline-secondary">Annuler</a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

{%  extends 'admin/base.html.twig' %}
{% block title %}Avis{% endblock %}
{% block content %}
<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">⭐ Avis</h1>
        <a href="{{ path('admin_avis_new') }}" class="btn btn-primary">➕ Nouveau</a>
    </div>

    {%  for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    {%  endfor %}

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Mentor</th>
                        <th>Auteur</th>
                        <th>Note</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {%  for item in items %}
                    <tr>
                        <td>{{ item.id }}</td>
                        <td>{{ item.mentor.utilisateur.nomComplet ?? 'N/A' }}</td>
                        <td>{{ item.auteur.nomComplet }}</td>
                        <td>{{ item.note ~ '/5 ⭐' }}</td>
                        <td class="text-center">
<a href="{{ path('admin_avis_show', {'id': item.id}) }}" class="btn btn-sm btn-info">👁️</a>
                                <a href="{{ path('admin_avis_edit', {'id': item.id}) }}" class="btn btn-sm btn-warning">✏️</a>
                                <form method="post" action="{{ path('admin_avis_delete', {'id': item.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Confirmer la suppression ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                                <button type="submit" class="btn btn-sm btn-danger">🗑️</button>
                            </form>
                        </td>
                    </tr>
                    {%  else %}
                    <tr><td colspan="5" class="text-center text-muted py-4">Aucun enregistrement.</td></tr>
                    {%  endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

{%  extends 'admin/base.html.twig' %}
{% block title %}Détail Avis{% endblock %}
{% block content %}
<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">⭐ Détail Avis</h1>
        <div>
<a href="{{ path('admin_avis_edit', {'id': item.id}) }}" class="btn btn-warning">✏️ Modifier</a>
            <a href="{{ path('admin_avis_index') }}" class="btn btn-secondary">← Retour</a>
        </div>
    </div>
    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4">ID</dt>
                <dd class="col-sm-8">{{ item.id }}</dd>
                        <dt class="col-sm-4">Mentor</dt>
                        <dd class="col-sm-8">{{{ item.mentor.utilisateur.nomComplet ?? 'N/A' }}}</dd>
                        <dt class="col-sm-4">Auteur</dt>
                        <dd class="col-sm-8">{{{ item.auteur.nomComplet }}}</dd>
                        <dt class="col-sm-4">Note</dt>
                        <dd class="col-sm-8">{{{ item.note ~ ' / 5' }}}</dd>
                        <dt class="col-sm-4">Commentaire</dt>
                        <dd class="col-sm-8">{{{ item.commentaire }}}</dd>

            </dl>
            <form method="post" action="{{ path('admin_avis_delete', {{ 'id': item.id }}) }}"
                  onsubmit="return confirm('Supprimer cet élément ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                <button type="submit" class="btn btn-danger btn-sm">🗑️ Supprimer</button>
            </form>
        </div>
    </div>
</div>
{% endblock %}

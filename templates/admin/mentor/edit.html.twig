{% extends 'admin/base.html.twig' %}

{% block title %}Modifier le Mentor{% endblock %}

{% block content %}
<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">✏️ Modifier le Mentor</h1>
        <a href="{{ path('admin_mentor_index') }}" class="btn btn-secondary">← Retour</a>
    </div>

    <div class="card">
        <div class="card-body">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            {% if form.vars.errors|length > 0 %}
                <div class="alert alert-warning">Veuillez corriger les erreurs.</div>
            {% endif %}

            <div class="row">
                <div class="col-md-6 mb-3">{{ form_row(form.utilisateur) }}</div>
                <div class="col-md-6 mb-3">{{ form_row(form.specialite) }}</div>
            </div>
            <div class="mb-3">{{ form_row(form.bio) }}</div>
            <div class="mb-3">{{ form_row(form.experience) }}</div>
            <div class="col-md-4 mb-3">{{ form_row(form.tarif) }}</div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-warning">💾 Mettre à jour</button>
                <a href="{{ path('admin_mentor_show', {'id': mentor.id}) }}" class="btn btn-outline-secondary">Annuler</a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

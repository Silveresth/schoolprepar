{% extends 'admin/base.html.twig' %}

{% block title %}Nouvel Utilisateur{% endblock %}

{% block content %}
<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">➕ Nouvel Utilisateur</h1>
        <a href="{{ path('admin_utilisateur_index') }}" class="btn btn-secondary">← Retour</a>
    </div>

    <div class="card">
        <div class="card-body">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            {% if form.vars.errors|length > 0 %}
                <div class="alert alert-danger">
                    Veuillez corriger les erreurs du formulaire.
                </div>
            {% endif %}

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold">Prénom <span class="text-danger">*</span></label>
                    {{ form_widget(form.prenom, {'attr': {'class': 'form-control' ~ (form_errors(form.prenom) is not empty ? ' is-invalid' : ''), 'placeholder': 'Prénom'}}) }}
                    <div class="invalid-feedback">{{ form_errors(form.prenom) }}</div>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold">Nom <span class="text-danger">*</span></label>
                    {{ form_widget(form.nom, {'attr': {'class': 'form-control' ~ (form_errors(form.nom) is not empty ? ' is-invalid' : ''), 'placeholder': 'Nom de famille'}}) }}
                    <div class="invalid-feedback">{{ form_errors(form.nom) }}</div>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                {{ form_widget(form.email, {'attr': {'class': 'form-control' ~ (form_errors(form.email) is not empty ? ' is-invalid' : ''), 'placeholder': 'exemple@email.com'}}) }}
                <div class="invalid-feedback">{{ form_errors(form.email) }}</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Rôle <span class="text-danger">*</span></label>
                {{ form_widget(form.role, {'attr': {'class': 'form-select'}}) }}
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Mot de passe <span class="text-danger">*</span></label>
                {{ form_widget(form.password, {'attr': {'class': 'form-control' ~ (form_errors(form.password) is not empty ? ' is-invalid' : ''), 'placeholder': 'Minimum 6 caractères'}}) }}
                <div class="invalid-feedback">{{ form_errors(form.password) }}</div>
            </div>

            <div class="col-12 mb-3">{{ form_row(form.photoFile) }}</div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">💾 Créer l'utilisateur</button>
                <a href="{{ path('admin_utilisateur_index') }}" class="btn btn-outline-secondary">Annuler</a>
            </div>

            {{ form_end(form) }}

        </div>
    </div>
</div>
{% endblock %}

{% extends 'admin/base.html.twig' %}
{% block title %}Détail Utilisateur{% endblock %}
{% block content %}
<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">👤 {{ utilisateur.nomComplet }}</h1>
        <div>
            <a href="{{ path('admin_utilisateur_edit', {'id': utilisateur.id}) }}" class="btn btn-warning">✏️ Modifier</a>
            <a href="{{ path('admin_utilisateur_index') }}" class="btn btn-secondary">← Retour</a>
        </div>
    </div>
    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">ID</dt><dd class="col-sm-9">{{ utilisateur.id }}</dd>
                <dt class="col-sm-3">Prénom</dt><dd class="col-sm-9">{{ utilisateur.prenom }}</dd>
                <dt class="col-sm-3">Nom</dt><dd class="col-sm-9">{{ utilisateur.nom }}</dd>
                <dt class="col-sm-3">Email</dt><dd class="col-sm-9">{{ utilisateur.email }}</dd>
                <dt class="col-sm-3">Rôle</dt>
                <dd class="col-sm-9">
                    {% if utilisateur.role == 'ROLE_ADMIN' %}<span class="badge bg-danger">Administrateur</span>
                    {% elseif utilisateur.role == 'ROLE_CONSEILLER' %}<span class="badge bg-warning text-dark">Conseiller</span>
                    {% else %}<span class="badge bg-secondary">Utilisateur</span>{% endif %}
                </dd>
            </dl>
            <hr>
            <form method="post" action="{{ path('admin_utilisateur_delete', {'id': utilisateur.id}) }}"
                  onsubmit="return confirm('Supprimer cet utilisateur définitivement ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ utilisateur.id) }}">
                <button type="submit" class="btn btn-danger btn-sm">🗑️ Supprimer</button>
            </form>
        </div>
    </div>
</div>
{% endblock %}

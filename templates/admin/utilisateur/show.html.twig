{% extends 'admin/base.html.twig' %}
{% block title %}{{ utilisateur.nomComplet }}{% endblock %}
{% block page_header %}<h1 class="h3 mb-3">Utilisateur : <strong>{{ utilisateur.nomComplet }}</strong></h1>{% endblock %}
{% block body %}
<div class="row">
    <div class="col-md-8">
        <div class="card"><div class="card-header"><h5 class="card-title mb-0">Profil</h5></div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4">Prénom</dt><dd class="col-sm-8">{{ utilisateur.prenom }}</dd>
                <dt class="col-sm-4">Nom</dt><dd class="col-sm-8">{{ utilisateur.nom }}</dd>
                <dt class="col-sm-4">Email</dt><dd class="col-sm-8">{{ utilisateur.email }}</dd>
                <dt class="col-sm-4">Rôle</dt><dd class="col-sm-8"><span class="badge bg-primary">{{ utilisateur.role }}</span></dd>
            </dl>
        </div></div>
        {% if utilisateur.evenements|length > 0 %}
        <div class="card mt-3"><div class="card-header"><h5 class="card-title mb-0">Événements inscrits ({{ utilisateur.evenements|length }})</h5></div>
        <ul class="list-group list-group-flush">
            {% for ev in utilisateur.evenements %}
            <li class="list-group-item d-flex justify-content-between">
                <span>{{ ev.titre }}</span>
                <small class="text-muted">{{ ev.dateDebut|date('d/m/Y') }}</small>
            </li>
            {% endfor %}
        </ul></div>
        {% endif %}
    </div>
    <div class="col-md-4">
        <div class="card"><div class="card-body d-flex flex-column gap-2">
            <a href="{{ path('admin_utilisateur_edit', {id: utilisateur.id}) }}" class="btn btn-warning w-100">Modifier</a>
            <form method="post" action="{{ path('admin_utilisateur_delete', {id: utilisateur.id}) }}" onsubmit="return confirm('Supprimer cet utilisateur ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ utilisateur.id) }}">
                <button type="submit" class="btn btn-danger w-100">Supprimer</button>
            </form>
            <a href="{{ path('admin_utilisateur_index') }}" class="btn btn-secondary w-100">Retour à la liste</a>
        </div></div>
    </div>
</div>
{% endblock %}

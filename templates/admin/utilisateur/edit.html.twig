{% extends 'admin/base.html.twig' %}

{% block title %}Modifier Utilisateur{% endblock %}

{% block content %}
<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">✏️ Modifier l'Utilisateur</h1>
        <a href="{{ path('admin_utilisateur_index') }}" class="btn btn-secondary">← Retour</a>
    </div>

    <div class="card">
        <div class="card-body">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'needs-validation'}}) }}

            {% if form.vars.errors|length > 0 %}
                <div class="alert alert-danger">
                    <strong>Erreurs :</strong>
                    {{ form_errors(form) }}
                </div>
            {% endif %}

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold">Prénom</label>
                    {{ form_widget(form.prenom, {'attr': {'class': 'form-control' ~ (form_errors(form.prenom) is not empty ? ' is-invalid' : '')}}) }}
                    <div class="invalid-feedback">{{ form_errors(form.prenom) }}</div>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold">Nom</label>
                    {{ form_widget(form.nom, {'attr': {'class': 'form-control' ~ (form_errors(form.nom) is not empty ? ' is-invalid' : '')}}) }}
                    <div class="invalid-feedback">{{ form_errors(form.nom) }}</div>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Email</label>
                {{ form_widget(form.email, {'attr': {'class': 'form-control' ~ (form_errors(form.email) is not empty ? ' is-invalid' : '')}}) }}
                <div class="invalid-feedback">{{ form_errors(form.email) }}</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Rôle</label>
                {{ form_widget(form.role, {'attr': {'class': 'form-select'}}) }}
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Nouveau mot de passe <small class="text-muted">(laisser vide pour ne pas changer)</small></label>
                {{ form_widget(form.password, {'attr': {'class': 'form-control', 'placeholder': 'Laisser vide pour garder l\'actuel'}}) }}
                <div class="invalid-feedback">{{ form_errors(form.password) }}</div>
            </div>

            <div class="col-12 mb-3">{{ form_row(form.photoFile) }}</div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">💾 Mettre à jour</button>
                <a href="{{ path('admin_utilisateur_index') }}" class="btn btn-outline-secondary">Annuler</a>
            </div>

            {{ form_end(form) }}

        </div>
    </div>
</div>
{% endblock %}

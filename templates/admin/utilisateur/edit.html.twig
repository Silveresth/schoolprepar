{% extends 'admin/base.html.twig' %}
{% block title %}Modifier - {{ utilisateur.nomComplet }}{% endblock %}
{% block page_header %}<h1 class="h3 mb-3">Modifier : <strong>{{ utilisateur.nomComplet }}</strong></h1>{% endblock %}
{% block body %}
<div class="card"><div class="card-header"><h5 class="card-title mb-0">Modifier l'utilisateur</h5></div>
<div class="card-body">
    <p class="text-muted small mb-3"><i data-feather="info" style="width:14px;height:14px;"></i> Laissez le champ mot de passe vide pour ne pas le modifier.</p>
    {{ form_start(form) }}
    <div class="row">
        <div class="col-md-6 mb-3">{{ form_row(form.prenom) }}</div>
        <div class="col-md-6 mb-3">{{ form_row(form.nom) }}</div>
        <div class="col-md-6 mb-3">{{ form_row(form.email) }}</div>
        <div class="col-md-6 mb-3">{{ form_row(form.password) }}</div>
        <div class="col-md-6 mb-3">{{ form_row(form.role) }}</div>
    </div>
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-warning">Mettre à jour</button>
        <a href="{{ path('admin_utilisateur_index') }}" class="btn btn-secondary">Annuler</a>
    </div>
    {{ form_end(form) }}
</div></div>
{% endblock %}

{% extends 'admin/base.html.twig' %}
{% block title %}Utilisateurs{% endblock %}
{% block content %}
<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">👥 Gestion des Utilisateurs</h1>
        <a href="{{ path('admin_utilisateur_new') }}" class="btn btn-primary">➕ Nouvel Utilisateur</a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    {% endfor %}

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th><th>Nom complet</th><th>Email</th><th>Rôle</th><th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for utilisateur in utilisateurs %}
                    <tr>
                        <td>{{ utilisateur.id }}</td>
                        <td><strong>{{ utilisateur.nomComplet }}</strong></td>
                        <td>{{ utilisateur.email }}</td>
                        <td>
                            {% if utilisateur.role == 'ROLE_ADMIN' %}
                                <span class="badge bg-danger">Admin</span>
                            {% elseif utilisateur.role == 'ROLE_CONSEILLER' %}
                                <span class="badge bg-warning text-dark">Conseiller</span>
                            {% else %}
                                <span class="badge bg-secondary">Utilisateur</span>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            <a href="{{ path('admin_utilisateur_show', {'id': utilisateur.id}) }}" class="btn btn-sm btn-info">👁️</a>
                            <a href="{{ path('admin_utilisateur_edit', {'id': utilisateur.id}) }}" class="btn btn-sm btn-warning">✏️</a>
                            <form method="post" action="{{ path('admin_utilisateur_delete', {'id': utilisateur.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Supprimer cet utilisateur ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ utilisateur.id) }}">
                                <button type="submit" class="btn btn-sm btn-danger">🗑️</button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="5" class="text-center text-muted py-4">Aucun utilisateur enregistré.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

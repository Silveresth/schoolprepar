{% extends 'admin/base.html.twig' %}
{% block title %}Utilisateurs - Admin{% endblock %}
{% block page_header %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0"><strong>Utilisateurs</strong></h1>
        <a href="{{ path('admin_utilisateur_new') }}" class="btn btn-primary">+ Nouvel utilisateur</a>
    </div>
{% endblock %}
{% block body %}
{% for type, messages in app.flashes %}{% for message in messages %}
<div class="alert alert-{{ type == 'success' ? 'success' : 'danger' }} alert-dismissible fade show">
    {{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>{% endfor %}{% endfor %}
<div class="card">
    <div class="card-header"><h5 class="card-title mb-0">Liste des utilisateurs ({{ utilisateurs|length }})</h5></div>
    <table class="table table-hover my-0">
        <thead><tr><th>#</th><th>Nom complet</th><th>Email</th><th>Rôle</th><th>Actions</th></tr></thead>
        <tbody>
        {% for u in utilisateurs %}
        <tr>
            <td>{{ loop.index }}</td>
            <td><strong>{{ u.prenom }} {{ u.nom }}</strong></td>
            <td>{{ u.email }}</td>
            <td>
                {% if u.role == 'ROLE_ADMIN' %}<span class="badge bg-danger">Admin</span>
                {% elseif u.role == 'ROLE_CONSEILLER' %}<span class="badge bg-warning text-dark">Conseiller</span>
                {% else %}<span class="badge bg-secondary">Utilisateur</span>{% endif %}
            </td>
            <td>
                <a href="{{ path('admin_utilisateur_show', {id: u.id}) }}" class="btn btn-sm btn-outline-info">Voir</a>
                <a href="{{ path('admin_utilisateur_edit', {id: u.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
                <form method="post" action="{{ path('admin_utilisateur_delete', {id: u.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ u.id) }}">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                </form>
            </td>
        </tr>
        {% else %}
        <tr><td colspan="5" class="text-center py-4 text-muted">Aucun utilisateur.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

{% extends 'admin/base.html.twig' %}
{% block title %}Établissements - Admin{% endblock %}
{% block page_header %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0"><strong>Établissements</strong></h1>
        <a href="{{ path('admin_etablissement_new') }}" class="btn btn-primary">
            <i data-feather="plus" class="me-1"></i> Nouvel établissement
        </a>
    </div>
{% endblock %}
{% block body %}
{% for type, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ type == 'success' ? 'success' : 'danger' }} alert-dismissible fade show">
            {{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endfor %}
<div class="card">
    <div class="card-header"><h5 class="card-title mb-0">Liste des établissements ({{ etablissements|length }})</h5></div>
    <table class="table table-hover my-0">
        <thead><tr><th>#</th><th>Nom</th><th>Ville</th><th>Adresse</th><th>Nb filières</th><th>Actions</th></tr></thead>
        <tbody>
        {% for etab in etablissements %}
        <tr>
            <td>{{ loop.index }}</td>
            <td><strong>{{ etab.nom }}</strong></td>
            <td>{{ etab.ville }}</td>
            <td>{{ etab.adresse }}</td>
            <td><span class="badge bg-primary">{{ etab.filieres|length }}</span></td>
            <td>
                <a href="{{ path('admin_etablissement_show', {id: etab.id}) }}" class="btn btn-sm btn-outline-info">Voir</a>
                <a href="{{ path('admin_etablissement_edit', {id: etab.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
                <form method="post" action="{{ path('admin_etablissement_delete', {id: etab.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cet établissement ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ etab.id) }}">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                </form>
            </td>
        </tr>
        {% else %}
        <tr><td colspan="6" class="text-center py-4 text-muted">Aucun établissement. <a href="{{ path('admin_etablissement_new') }}">En créer un</a></td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

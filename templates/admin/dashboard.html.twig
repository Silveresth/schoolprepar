{% extends 'admin/base.html.twig' %}

{% block title %}Tableau de bord — SchoolPrepar Admin{% endblock %}

{% block body %}
<div class="container-fluid p-0">

    <div class="mb-4">
        <h1 class="h3 d-inline align-middle">🎓 Tableau de bord</h1>
        <p class="text-muted mt-1">
            Bienvenue, <strong>{{ app.user.nomComplet }}</strong> — Administration SchoolPrepar
        </p>
    </div>

    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show">
                {{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <!-- Statistiques -->
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-4 col-sm-6">
            <a href="{{ path('admin_utilisateur_index') }}" class="text-decoration-none">
                <div class="card border-0 shadow-sm">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="p-3 rounded-3 bg-primary bg-opacity-10"><span class="fs-3">👥</span></div>
                        <div>
                            <div class="text-muted small">Utilisateurs</div>
                            <div class="fw-bold fs-4">{{ stats.utilisateurs }}</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-xl-3 col-md-4 col-sm-6">
            <a href="{{ path('admin_mentor_index') }}" class="text-decoration-none">
                <div class="card border-0 shadow-sm">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="p-3 rounded-3 bg-success bg-opacity-10"><span class="fs-3">🧑‍🏫</span></div>
                        <div>
                            <div class="text-muted small">Mentors</div>
                            <div class="fw-bold fs-4">{{ stats.mentors }}</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-xl-3 col-md-4 col-sm-6">
            <a href="{{ path('admin_etablissement_index') }}" class="text-decoration-none">
                <div class="card border-0 shadow-sm">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="p-3 rounded-3 bg-warning bg-opacity-10"><span class="fs-3">🏫</span></div>
                        <div>
                            <div class="text-muted small">Établissements</div>
                            <div class="fw-bold fs-4">{{ stats.etablissements }}</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-xl-3 col-md-4 col-sm-6">
            <a href="{{ path('admin_filiere_index') }}" class="text-decoration-none">
                <div class="card border-0 shadow-sm">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="p-3 rounded-3 bg-info bg-opacity-10"><span class="fs-3">📚</span></div>
                        <div>
                            <div class="text-muted small">Filières</div>
                            <div class="fw-bold fs-4">{{ stats.filieres }}</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-xl-3 col-md-4 col-sm-6">
            <a href="{{ path('admin_evenement_index') }}" class="text-decoration-none">
                <div class="card border-0 shadow-sm">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="p-3 rounded-3 bg-danger bg-opacity-10"><span class="fs-3">📅</span></div>
                        <div>
                            <div class="text-muted small">Événements</div>
                            <div class="fw-bold fs-4">{{ stats.evenements }}</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-xl-3 col-md-4 col-sm-6">
            <a href="{{ path('admin_forum_index') }}" class="text-decoration-none">
                <div class="card border-0 shadow-sm">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="p-3 rounded-3 bg-secondary bg-opacity-10"><span class="fs-3">💬</span></div>
                        <div>
                            <div class="text-muted small">Topics Forum</div>
                            <div class="fw-bold fs-4">{{ stats.forums }}</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-xl-3 col-md-4 col-sm-6">
            <a href="{{ path('admin_rendez_vous_index') }}" class="text-decoration-none">
                <div class="card border-0 shadow-sm">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="p-3 rounded-3 bg-dark bg-opacity-10"><span class="fs-3">📆</span></div>
                        <div>
                            <div class="text-muted small">Rendez-vous</div>
                            <div class="fw-bold fs-4">{{ stats.rendezVous }}</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- Graphiques (stats) -->
    <div class="row g-3 mb-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 pb-2">
                    <h5 class="fw-bold mb-0">📊 Vue d’ensemble</h5>
                    <div class="text-muted small mt-1">Utilisateurs, Mentors, Établissements, Filières, Événements</div>
                </div>
                <div class="card-body">
                    <div class="position-relative" style="height:260px;">
                        <canvas id="statsChart" style="height:260px; width:100%;"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 pb-2">
                    <h5 class="fw-bold mb-0">💬 Autres indicateurs</h5>
                    <div class="text-muted small mt-1">Forums, Rendez-vous</div>
                </div>
                <div class="card-body">
                    <div class="position-relative" style="height:260px;">
                        <canvas id="extrasChart" style="height:260px; width:100%;"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Derniers inscrits -->
    <div class="row g-3">
        <div class="col-md-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 pb-2 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0">👥 Derniers utilisateurs inscrits</h5>
                    <a href="{{ path('admin_utilisateur_index') }}" class="btn btn-sm btn-outline-primary">Voir tout</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Nom</th>
                                    <th>Email</th>
                                    <th>Rôle</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% if recentUsers is empty %}
                                <tr><td colspan="4" class="text-center text-muted py-4">Aucun utilisateur.</td></tr>
                                {% else %}
                                {% for u in recentUsers %}
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold" style="width:32px;height:32px;font-size:.75rem;flex-shrink:0;">
                                                {{ u.prenom[0] ?? '?' }}{{ u.nom[0] ?? '' }}
                                            </div>
                                            {{ u.nomComplet }}
                                        </div>
                                    </td>
                                    <td class="text-muted small">{{ u.email }}</td>
                                    <td>
                                        <span class="badge bg-{{ u.role == 'ROLE_ADMIN' ? 'danger' : (u.role == 'ROLE_CONSEILLER' ? 'warning' : 'secondary') }}">
                                            {{ u.role }}
                                        </span>
                                    </td>
                                    <td>
                                        <a href="{{ path('admin_utilisateur_show', {'id': u.id}) }}" class="btn btn-sm btn-outline-secondary">Voir</a>
                                    </td>
                                </tr>
                                {% endfor %}
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm border-start border-danger border-3 mb-3">
                <div class="card-body">
                    <h6 class="text-danger">🔐 Zone sécurisée — ROLE_ADMIN</h6>
                    <p class="text-muted small mb-0">
                        Toutes les actions sont protégées par token CSRF. Les mots de passe sont hashés avec l'algorithme <code>auto</code>.
                    </p>
                </div>
            </div>
            <div class="card border-0 shadow-sm border-start border-info border-3">
                <div class="card-body">
                    <h6 class="text-info">ℹ️ Session active</h6>
                    <p class="text-muted small mb-0">
                        <strong>{{ app.user.email }}</strong><br>
                        <span class="badge bg-danger">{{ app.user.role }}</span><br>
                        <a href="{{ path('app_logout') }}" class="text-danger small">Se déconnecter</a>
                    </p>
                </div>
            </div>
        </div>
    </div>

</div>

{# Chart.js #}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
  (function () {
    const statsCanvas = document.getElementById('statsChart');
    const extrasCanvas = document.getElementById('extrasChart');

    if (statsCanvas) {
      new Chart(statsCanvas, {
        type: 'bar',
        data: {
          labels: ['Utilisateurs', 'Mentors', 'Établissements', 'Filières', 'Événements'],
          datasets: [{
            label: 'Nombre',
            data: [
              {{ stats.utilisateurs|default(0) }},
              {{ stats.mentors|default(0) }},
              {{ stats.etablissements|default(0) }},
              {{ stats.filieres|default(0) }},
              {{ stats.evenements|default(0) }}
            ],
            backgroundColor: ['#0d6efd', '#198754', '#ffc107', '#0dcaf0', '#dc3545'],
            borderRadius: 10
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
        }
      });
    }

    if (extrasCanvas) {
      new Chart(extrasCanvas, {
        type: 'doughnut',
        data: {
          labels: ['Forums', 'Rendez-vous'],
          datasets: [{
            data: [{{ stats.forums|default(0) }}, {{ stats.rendezVous|default(0) }}],
            backgroundColor: ['#6c757d', '#212529'],
            borderWidth: 0
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { position: 'bottom' } }
        }
      });
    }
  })();
</script>
{% endblock %}

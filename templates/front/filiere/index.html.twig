{% extends 'front/base.html.twig' %}

{% block title %}Filières - SchoolPrepar{% endblock %}

{% block titre_de_page %}
    <h1 class="h3 mb-3"><strong>Filières</strong></h1>
{% endblock %}

{% block Contenu_principal %}

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">Liste des filières ({{ filieres|length }})</h5>
    </div>
    <table class="table table-hover my-0">
        <thead>
            <tr>
                <th>#</th>
                <th>Nom de la filière</th>
                <th>Domaine</th>
                <th>Établissement</th>
                <th>Durée</th>
                <th>En savoir plus</th>
            </tr>
        </thead>
        <tbody>
            {% for filiere in filieres %}
            <tr>
                <td>{{ loop.index }}</td>
                <td><strong>{{ filiere.nom }}</strong></td>
                <td>{{ filiere.domaine }}</td>
                <td>{{ filiere.etablissement }}</td>
                <td>{{ filiere.duree }}</td>
                <td>
                    <a href=\"#!\" class=\"btn btn-outline-primary btn-sm\" onclick=\"alert('Page détail filière à implémenter'); return false;\">En savoir plus</a>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="5" class="text-center text-muted py-4">Aucune filière pour le moment.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}

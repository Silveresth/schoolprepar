{% extends 'front/base.html.twig' %}
{% block title %}Filières — SchoolPrepar{% endblock %}

{% block body %}
<section class="mk-hero" style="min-height:40vh;padding:7rem 0 3rem;">
    <div class="container">
        <div class="mk-hero-content">
            <h1>📚 Toutes les Filières</h1>
            <p>Explorez les formations disponibles dans les établissements du Togo</p>
        </div>
    </div>
</section>

<section class="mk-section" style="background:#f8f9fa;">
    <div class="container">
        <div class="row g-4">
            {% for filiere in filieres %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0" style="border-radius:16px;box-shadow:0 4px 20px rgba(0,0,0,.07);transition:transform .2s,box-shadow .2s;overflow:hidden;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 12px 32px rgba(26,115,232,.15)'" onmouseout="this.style.transform='';this.style.boxShadow='0 4px 20px rgba(0,0,0,.07)'">
                    <div style="height:5px;background:linear-gradient(90deg,#1A73E8,#49a3f1);"></div>
                    <div class="card-body p-4">
                        {% set img = filiere.imageFilename %}
                        <div style="width:100%;height:120px;border-radius:18px;overflow:hidden;background:#fff;flex-shrink:0;border:2px solid rgba(26,115,232,.15);">
                            <img
                                src="{{ img ? asset('img/photos/' ~ img) : asset('img/photos/unsplash-2.jpg') }}"
                                alt="Image filière"
                                style="width:100%;height:100%;object-fit:cover;"
                            />
                        </div>

                        <div class="mt-3">
                            <h6 class="fw-bold mb-1" style="color:#1a202c;font-size:.95rem;line-height:1.3;">{{ filiere.nom }}</h6>
                            <div class="text-muted" style="font-size:.78rem;"><i class="fas fa-university fa-xs me-1"></i>{{ filiere.etablissement.nom }}</div>

                            <p class="text-muted mb-3 mt-2" style="font-size:.83rem;line-height:1.7;">{{ filiere.description|length > 120 ? filiere.description|slice(0,120) ~ '…' : filiere.description }}</p>

                            {% if filiere.debouche %}
                            <div class="mb-3 p-2 rounded-2" style="background:#f8f9fa;font-size:.78rem;color:#4a5568;">
                                <i class="fas fa-briefcase me-1 text-primary"></i>{{ filiere.debouche|slice(0,80) }}
                            </div>
                            {% endif %}

                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span style="font-size:.75rem;padding:4px 12px;background:#f0f7ff;color:#1A73E8;border-radius:20px;font-weight:600;">{{ filiere.niveauRequis }}</span>
                                </div>
                                <a href="{{ path('front_filiere_details_show', {'id': filiere.id}) }}" class="btn btn-primary btn-sm w-100" style="border-radius:8px;font-size:.8rem;margin-top:.6rem;">Voir les détails</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {% else %}

            <div class="col-12 text-center py-5 text-muted">
                <i class="fas fa-inbox fa-3x mb-3 d-block opacity-25"></i>
                Aucune filière disponible pour le moment.
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}

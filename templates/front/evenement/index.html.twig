{% extends 'front/base.html.twig' %}
{% block title %}Événements — SchoolPrepar{% endblock %}

{% block body %}
<section class="mk-hero" style="min-height:40vh;padding:7rem 0 3rem;">
    <div class="container">
        <div class="mk-hero-content">
            <h1>📅 Événements à venir</h1>
            <p>Portes ouvertes, salons, conférences d'orientation…</p>
        </div>
    </div>
</section>

<section class="mk-section" style="background:#f8f9fa;">
    <div class="container">
        <div class="row g-4">
            {% for evenement in evenements %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0" style="border-radius:16px;box-shadow:0 4px 20px rgba(0,0,0,.07);transition:transform .2s,box-shadow .2s;overflow:hidden;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 12px 32px rgba(251,140,0,.15)'" onmouseout="this.style.transform='';this.style.boxShadow='0 4px 20px rgba(0,0,0,.07)'">
                    <div style="height:5px;background:linear-gradient(90deg,#fb8c00,#ffa726);"></div>
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div style="min-width:48px;text-align:center;background:linear-gradient(135deg,#fff3e0,#ffe0b2);border-radius:12px;padding:.6rem .5rem;">
                                <div style="font-size:1.2rem;font-weight:800;color:#e65100;line-height:1;">{{ evenement.dateDebut|date('d') }}</div>
                                <div style="font-size:.65rem;text-transform:uppercase;color:#e65100;font-weight:600;letter-spacing:.5px;">{{ evenement.dateDebut|date('M') }}</div>
                            </div>
                            <div class="flex-fill" style="min-width:0;">
                                <h6 class="fw-bold mb-0" style="color:#1a202c;font-size:.9rem;line-height:1.3;">{{ evenement.titre }}</h6>
                                {% if evenement.etablissement %}<div class="text-muted" style="font-size:.75rem;">{{ evenement.etablissement.nom }}</div>{% endif %}
                            </div>
                        </div>
                        <p class="text-muted mb-3" style="font-size:.82rem;line-height:1.6;">{{ evenement.description|slice(0,100) }}…</p>
                        <div style="font-size:.77rem;color:#718096;margin-bottom:.4rem;"><i class="fas fa-clock fa-xs me-1"></i>{{ evenement.dateDebut|date('H:i') }} → {{ evenement.dateFin|date('H:i') }}</div>
                        <div style="font-size:.77rem;color:#718096;margin-bottom:1rem;"><i class="fas fa-map-marker-alt fa-xs me-1"></i>{{ evenement.lieu }}</div>
                        <a href="{{ path('front_evenement_show', {'id': evenement.id}) }}" class="btn btn-sm w-100" style="background:linear-gradient(135deg,#fb8c00,#ffa726);color:#fff;border:none;border-radius:8px;font-size:.8rem;">Voir les détails</a>
                    </div>
                </div>
            </div>
            {% else %}
            <div class="col-12 text-center py-5 text-muted">
                <i class="fas fa-calendar-times fa-3x mb-3 d-block opacity-25"></i>
                Aucun événement programmé pour le moment.
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}

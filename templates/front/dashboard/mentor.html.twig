{% extends 'front/base.html.twig' %}
{% block title %}Mon espace conseiller — SchoolPrepar{% endblock %}

{% block body %}
<!-- Hero -->
<section class="mk-hero" style="min-height:32vh;padding:7rem 0 3rem;">
    <div class="container">
        <div class="mk-hero-content">
            <h1>👋 Bonjour, {{ user.prenom }} !</h1>
            <p class="mb-3">Bienvenue dans votre espace conseiller / mentor. Gérez vos rendez-vous, répondez aux questions et accompagnez les étudiants.</p>
            <div class="d-flex flex-wrap gap-2">
                <a href="{{ path('front_chat_index') }}" class="mk-btn-primary">
                    💬 Messagerie
                </a>
                <a href="{{ path('front_forum_index') }}" class="mk-btn-outline">
                    📢 Forum
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Indicateurs -->
<section style="background:#fff;padding:2rem 0;border-bottom:1px solid #f0f0f0;">
    <div class="container">
        <div class="row g-3 text-center">
            <div class="col-6 col-md-3">
                <div class="mk-card card p-3">
                    <div class="fs-1 mb-1">📅</div>
                    <div class="fw-bold text-primary">Rendez-vous</div>
                    <div class="text-muted small">{{ rendezVous|length }} au total</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="mk-card card p-3">
                    <div class="fs-1 mb-1">💬</div>
                    <div class="fw-bold text-success">Forum</div>
                    <div class="text-muted small">Répondre aux questions</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="mk-card card p-3">
                    <div class="fs-1 mb-1">📅</div>
                    <div class="fw-bold text-warning">Événements</div>
                    <div class="text-muted small">{{ prochainsEvenements|length }} à venir</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="mk-card card p-3">
                    <div class="fs-1 mb-1">✉️</div>
                    <div class="fw-bold text-danger">Messages</div>
                    <div class="text-muted small">Messagerie privée</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Contenu -->
<section style="background:#f8f9fa;padding:3rem 0;">
    <div class="container">
        <div class="row g-4">

            <!-- Actions conseiller -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-0 pt-4 pb-0">
                        <h5 class="fw-bold mb-0">⚡ Mes actions</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            <a href="{{ path('front_chat_index') }}" class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3">
                                <span class="fs-4">💬</span>
                                <div>
                                    <div class="fw-semibold">Messagerie</div>
                                    <div class="text-muted small">Répondre aux étudiants</div>
                                </div>
                            </a>
                            <a href="{{ path('front_forum_index') }}" class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3">
                                <span class="fs-4">📢</span>
                                <div>
                                    <div class="fw-semibold">Forum</div>
                                    <div class="text-muted small">Répondre aux questions</div>
                                </div>
                            </a>
                            <a href="{{ path('front_evenement_index') }}" class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3">
                                <span class="fs-4">📅</span>
                                <div>
                                    <div class="fw-semibold">Événements</div>
                                    <div class="text-muted small">Voir les prochains salons</div>
                                </div>
                            </a>
                            <a href="{{ path('filiere') }}" class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3">
                                <span class="fs-4">📚</span>
                                <div>
                                    <div class="fw-semibold">Filières</div>
                                    <div class="text-muted small">Consulter les programmes</div>
                                </div>
                            </a>
                            <a href="{{ path('front_profile_index') }}" class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3">
                                <span class="fs-4">👤</span>
                                <div>
                                    <div class="fw-semibold">Mon profil</div>
                                    <div class="text-muted small">Modifier mes informations</div>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Rendez-vous récents -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold mb-0">📅 Rendez-vous récents</h5>
                    </div>
                    <div class="card-body">
                        {% if rendezVous is empty %}
                            <div class="text-center text-muted py-4">
                                <div class="fs-1">📭</div>
                                <p>Aucun rendez-vous pour l'instant.</p>
                            </div>
                        {% else %}
                            {% for rdv in rendezVous %}
                            <div class="d-flex align-items-start gap-3 mb-3 pb-3 {{ not loop.last ? 'border-bottom' : '' }}">
                                <div class="text-center" style="min-width:48px;">
                                    <div class="fw-bold text-primary" style="font-size:1.3rem;">
                                        {{ rdv.date ? rdv.date|date('d') : '—' }}
                                    </div>
                                    <div class="text-muted small text-uppercase">
                                        {{ rdv.date ? rdv.date|date('M') : '' }}
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-semibold">
                                        {{ rdv.idEleve ? rdv.idEleve.nomComplet : 'Étudiant' }}
                                    </div>
                                    <div class="mt-1">
                                        <span class="badge bg-{{ rdv.statut == 'confirme' ? 'success' : (rdv.statut == 'annule' ? 'danger' : 'warning') }}">
                                            {{ rdv.statut|capitalize }}
                                        </span>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- Messages reçus + événements + forum -->
            <div class="col-lg-4">
                <!-- Messages reçus -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                        <h6 class="fw-bold mb-0">✉️ Messages reçus</h6>
                        <span class="badge bg-primary">{{ messagesRecus|length }}</span>
                    </div>
                    <div class="card-body">
                        {% if messagesRecus is empty %}
                            <p class="text-muted text-center py-3 small">Aucun message reçu.</p>
                        {% else %}
                            {% for msg in messagesRecus %}
                            <div class="d-flex align-items-start gap-2 mb-2 pb-2 {{ not loop.last ? 'border-bottom' : '' }}">
                                <span class="text-primary mt-1">✉️</span>
                                <div class="flex-fill" style="min-width:0;">
                                    <div class="fw-semibold small">{{ msg.expediteur.nomComplet }}</div>
                                    <div class="text-muted" style="font-size:.75rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                        {{ msg.contenu|slice(0, 60) }}…
                                    </div>
                                </div>
                                <a href="{{ path('front_chat_conversation', {'id': msg.expediteur.id}) }}"
                                   class="btn btn-xs btn-outline-primary" style="font-size:.7rem;padding:2px 6px;white-space:nowrap;">Répondre</a>
                            </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>

                <!-- Prochains événements -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                        <h6 class="fw-bold mb-0">📅 Prochains événements</h6>
                        <a href="{{ path('front_evenement_index') }}" class="btn btn-sm btn-outline-primary">Voir</a>
                    </div>
                    <div class="card-body">
                        {% if prochainsEvenements is empty %}
                            <p class="text-muted text-center py-3">Aucun événement.</p>
                        {% else %}
                            {% for evt in prochainsEvenements %}
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="text-primary">📅</span>
                                <div>
                                    <div class="fw-semibold small">{{ evt.titre ?? evt.nom ?? 'Événement' }}</div>
                                    <div class="text-muted" style="font-size:.75rem;">{{ evt.dateDebut ? evt.dateDebut|date('d/m/Y') : '' }}</div>
                                </div>
                            </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>

                <!-- Forum -->
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                        <h6 class="fw-bold mb-0">💬 Forum récent</h6>
                        <a href="{{ path('front_forum_index') }}" class="btn btn-sm btn-outline-success">Voir</a>
                    </div>
                    <div class="card-body">
                        {% if derniersForums is empty %}
                            <p class="text-muted text-center py-3">Aucun sujet.</p>
                        {% else %}
                            {% for forum in derniersForums %}
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="text-success">💬</span>
                                <span class="small fw-semibold">{{ forum.titre ?? forum.sujet ?? 'Sujet' }}</span>
                            </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
            </div>

        </div>

        <!-- Rappel badge -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card border-start border-success border-3 border-0 shadow-sm">
                    <div class="card-body d-flex align-items-center gap-3">
                        <span class="fs-3">🧑‍🏫</span>
                        <div>
                            <div class="fw-bold">Vous êtes conseiller / mentor</div>
                            <div class="text-muted small">
                                Vous avez accès aux mêmes fonctionnalités qu'un conseiller et qu'un mentor. Vous pouvez orienter les étudiants, animer le forum et gérer des rendez-vous.
                            </div>
                        </div>
                        <span class="badge bg-success ms-auto px-3 py-2">{{ user.role }}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% extends 'front/base.html.twig' %}
{% block title %}{{ mentor.utilisateur.nomComplet }} — Mentor{% endblock %}

{% block body %}
<section class="mk-hero" style="min-height:35vh;padding:7rem 0 3rem;">
    <div class="container">
        <div class="mk-hero-content">
            <span class="mk-badge-pill mb-2 d-inline-block" style="background:rgba(255,255,255,.2);color:#fff;">🧑‍🏫 Mentor</span>
            <h1>{{ mentor.utilisateur.nomComplet }}</h1>
            <p>{{ mentor.specialite }} — {{ mentor.tarif|number_format(0, ',', ' ') }} FCFA/h</p>
        </div>
    </div>
</section>

<section class="mk-section" style="background:#f8f9fa;">
    <div class="container">
        <div class="row g-4">

            {# Infos mentor #}
            <div class="col-lg-4">
                <div class="mk-card card mb-4">
                    <div class="card-body p-4">
                        <div class="text-center mb-3">
                            <div class="mx-auto mb-3" style="width:80px;height:80px;border-radius:50%;background:linear-gradient(195deg,#49a3f1,#1A73E8);display:flex;align-items:center;justify-content:center;font-size:2rem;color:#fff;">
                                👤
                            </div>
                            <h5 class="fw-bold">{{ mentor.utilisateur.nomComplet }}</h5>
                            <span class="mk-badge-pill">{{ mentor.specialite }}</span>
                        </div>
                        <hr>
                        <dl class="small mb-0">
                            <dt class="text-muted">Tarif</dt>
                            <dd class="fw-bold text-primary">{{ mentor.tarif|number_format(0, ',', ' ') }} FCFA/h</dd>
                            {% if mentor.experience %}
                            <dt class="text-muted mt-2">Expérience</dt>
                            <dd>{{ mentor.experience }}</dd>
                            {% endif %}
                            <dt class="text-muted mt-2">Avis</dt>
                            <dd>{{ mentor.avis|length }} avis reçus</dd>
                        </dl>
                    </div>
                </div>

                {# Prendre RDV — masqué si c'est le mentor lui-même qui consulte son propre profil #}
                {% if app.user and not isOwner and formRdv is not null %}
                    <div class="mk-card card mb-4">
                        <div class="card-header"><h6 class="mb-0">📅 Prendre rendez-vous</h6></div>
                        <div class="card-body p-4">
                            {{ form_start(formRdv, {'attr': {'novalidate': 'novalidate'}}) }}
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">Date et heure</label>
                                {{ form_widget(formRdv.date, {'attr': {'class': 'form-control form-control-sm'}}) }}
                                {% if form_errors(formRdv.date) is not empty %}
                                    <div class="text-danger small">{{ form_errors(formRdv.date) }}</div>
                                {% endif %}
                            </div>
                            <button type="submit" class="mk-btn-primary w-100" style="justify-content:center;padding:8px 0;font-size:.8rem;">
                                Demander un RDV
                            </button>
                            {{ form_end(formRdv) }}
                        </div>
                    </div>
                {% else %}
                    <div class="alert alert-info text-center small">
                        <a href="{{ path('app_login') }}">Connectez-vous</a> pour prendre un rendez-vous.
                    </div>
                {% endif %}

                {# Bouton envoyer un message (pour les étudiants) #}
                {% if app.user and not isOwner %}
                    <div class="mk-card card">
                        <div class="card-body p-3 text-center">
                            <a href="{{ path('front_chat_conversation', {'id': mentor.utilisateur.id}) }}"
                               class="mk-btn-primary w-100" style="justify-content:center;padding:10px 0;">
                                💬 Envoyer un message à {{ mentor.utilisateur.prenom }}
                            </a>
                        </div>
                    </div>
                {% endif %}

                {# Message si c'est le mentor qui regarde son propre profil #}
                {% if isOwner %}
                    <div class="alert alert-success text-center small">
                        <strong>C'est votre profil.</strong><br>
                        <a href="{{ path('mentor_dashboard') }}">← Retour à mon tableau de bord</a>
                    </div>
                {% endif %}
            </div>

            {# Bio + Avis #}
            <div class="col-lg-8">
                <div class="mk-card card mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">Biographie</h5>
                        <p class="text-muted" style="line-height:1.8;">{{ mentor.bio }}</p>
                    </div>
                </div>

                {# Avis existants #}
                <div class="mk-card card mb-4">
                    <div class="card-header"><h6 class="mb-0">⭐ Avis ({{ mentor.avis|length }})</h6></div>
                    <div class="card-body p-4">
                        {% for avis in mentor.avis %}
                            <div class="border-bottom pb-3 mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <strong class="small">{{ avis.auteur.nomComplet }}</strong>
                                    <span class="badge bg-warning text-dark">{{ avis.note }}/5 ⭐</span>
                                </div>
                                <p class="text-muted small mb-0">{{ avis.commentaire }}</p>
                            </div>
                        {% else %}
                            <p class="text-muted text-center small py-2">Aucun avis pour ce mentor. Soyez le premier !</p>
                        {% endfor %}
                    </div>
                </div>

                {# Formulaire avis — masqué pour le mentor lui-même #}
                {% if app.user and not isOwner and formAvis is not null %}
                    <div class="mk-card card">
                        <div class="card-header"><h6 class="mb-0">✍️ Laisser un avis</h6></div>
                        <div class="card-body p-4">
                            {{ form_start(formAvis, {'attr': {'novalidate': 'novalidate'}}) }}
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">Note</label>
                                {{ form_widget(formAvis.note, {'attr': {'class': 'form-select form-select-sm'}}) }}
                                {% if form_errors(formAvis.note) is not empty %}
                                    <div class="text-danger small">{{ form_errors(formAvis.note) }}</div>
                                {% endif %}
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">Commentaire</label>
                                {{ form_widget(formAvis.commentaire, {'attr': {'class': 'form-control form-control-sm', 'rows': 3, 'placeholder': 'Votre avis...'}}) }}
                                {% if form_errors(formAvis.commentaire) is not empty %}
                                    <div class="text-danger small">{{ form_errors(formAvis.commentaire) }}</div>
                                {% endif %}
                            </div>
                            <button type="submit" class="mk-btn-primary" style="padding:8px 20px;font-size:.8rem;">
                                Publier l'avis
                            </button>
                            {{ form_end(formAvis) }}
                        </div>
                    </div>
                {% else %}
                    <div class="alert alert-info text-center small">
                        <a href="{{ path('app_login') }}">Connectez-vous</a> pour laisser un avis.
                    </div>
                {% endif %}
            </div>

        </div>
        <div class="mt-3">
            <a href="{{ path('front_mentor_index') }}" class="text-muted small">← Retour aux mentors</a>
        </div>
    </div>
</section>
{% endblock %}

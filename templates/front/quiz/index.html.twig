{% extends 'front/base.html.twig' %}
{% block title %}Quiz & Tests — SchoolPrepar{% endblock %}

{% block body %}
<section class="mk-hero" style="min-height:35vh;padding:7rem 0 3rem;">
    <div class="container">
        <div class="mk-hero-content">
            <span class="mk-badge-pill mb-2 d-inline-block" style="background:rgba(255,255,255,.2);color:#fff;">
                <i class="fas fa-lightbulb me-2"></i>Auto-évaluation
            </span>
            <h1>Quiz & Tests</h1>
            <p>Répondez et enregistrez votre résultat pour obtenir des recommandations de parcours.</p>
        </div>
    </div>
</section>

<section class="mk-section" style="background:#f8f9fa;">
    <div class="container">
        <div class="row g-4">
            {% for test in tests %}
                <div class="col-md-6 col-lg-4">
                    <div class="mk-card card h-100">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-start gap-3 mb-3">
                                <div class="mk-card-icon bg-gradient-primary" style="width:44px;height:44px;font-size:1rem;">🧠</div>
                                <div>
                                    <h5 class="fw-bold" style="color:#344767;">{{ test.titre }}</h5>
                                    <div class="text-muted small">Disponible le {{ test.date|date('d/m/Y') }}</div>
                                </div>
                            </div>
                            <p class="text-muted small" style="line-height:1.6;">{{ test.description|slice(0,120) }}{% if test.description|length > 120 %}...{% endif %}</p>
                            <a href="{{ path('front_quiz_run', {'id': test.id}) }}" class="mk-btn-primary" style="padding:8px 18px;font-size:.8rem;">
                                Démarrer
                            </a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5 text-muted">
                    <i class="fas fa-clipboard-list fa-3x mb-3 d-block opacity-25"></i>
                    Aucun test disponible pour le moment.
                </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}


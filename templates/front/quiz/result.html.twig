{% extends 'front/base.html.twig' %}
{% block title %}Résultat — {{ test.titre }}{% endblock %}

{% block body %}
<section class="mk-hero" style="min-height:30vh;padding:7rem 0 3rem;">
    <div class="container">
        <div class="mk-hero-content">
            <span class="mk-badge-pill mb-2 d-inline-block" style="background:rgba(255,255,255,.2);color:#fff;">
                <i class="fas fa-chart-line me-2"></i>Résultat
            </span>
            <h1>{{ test.titre }}</h1>
            <p class="text-white" style="opacity:.85;">Votre score et vos prochaines étapes</p>
        </div>
    </div>
</section>

<section class="mk-section" style="background:#f8f9fa;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="mk-card card">
                    <div class="card-body p-4">
                        {% if result %}
                            <div class="text-center mb-4">
                                <div style="font-size:4rem;font-weight:800;color:#1A73E8;">{{ result.score|number_format(0, ',', ' ') }}</div>
                                <div class="text-muted">/100</div>
                                <div class="small text-muted">Enregistré le {{ result.date|date('d/m/Y H:i') }}</div>
                            </div>

                            {% set score = result.score|default(0) %}
                            {% if score >= 80 %}
                                <div class="alert alert-success">Excellent profil ! Pensez à explorer des formations exigeantes et challengantes.</div>
                            {% elseif score >= 50 %}
                                <div class="alert alert-info">Profil solide. Vous pouvez viser un parcours équilibré avec un accompagnement.</div>
                            {% else %}
                                <div class="alert alert-warning">Profil en découverte. Commencez par des parcours progressifs et demandez conseil à un mentor.</div>
                            {% endif %}

                            <div class="mt-3 text-muted small">
                                Score calculé à partir des points des réponses.
                            </div>


                            <div class="mt-4">
                                <a href="{{ path('front_mentor_index') }}" class="mk-btn-primary" style="padding:10px 22px;">
                                    <i class="fas fa-user-tie me-2"></i>Voir les mentors
                                </a>
                            </div>
                        {% else %}
                            <div class="alert alert-danger">Aucun résultat trouvé.</div>
                        {% endif %}
                    </div>
                </div>

                <div class="mt-3 d-flex justify-content-between">
                    <a href="{{ path('front_quiz_index') }}" class="text-muted small">← Retour</a>
                    <a href="{{ path('home') }}" class="text-muted small">Accueil</a>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}


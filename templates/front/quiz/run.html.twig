{% extends 'front/base.html.twig' %}
{% block title %}Démarrer — {{ test.titre }}{% endblock %}

{% block body %}
<section class="mk-hero" style="min-height:30vh;padding:7rem 0 3rem;">
    <div class="container">
        <div class="mk-hero-content">
            <span class="mk-badge-pill mb-2 d-inline-block" style="background:rgba(255,255,255,.2);color:#fff;">
                <i class="fas fa-pen-nib me-2"></i>Test
            </span>
            <h1>{{ test.titre }}</h1>
            <p class="text-white" style="opacity:.85;">{{ test.description }}</p>
        </div>
    </div>
</section>

<section class="mk-section" style="background:#f8f9fa;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="mk-card card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Évaluation</h5>
                        {% if existingResult %}
                            <span class="small text-muted">Dernier score : <strong>{{ existingResult.score|number_format(0, ',', ' ') }}</strong>/100</span>
                        {% endif %}
                    </div>
                    <div class="card-body p-4">
                        <form method="post">
                            <div class="mb-3">
                                <div class="alert alert-info mb-3">
                                    <strong>Quiz.</strong> Sélectionnez une réponse par question.
                                </div>

                                {% for q in test.questions %}
                                    <div class="mb-4">
                                        <div class="fw-bold">{{ q.contenu }}</div>
                                        <div class="mt-2">
                                            {% for r in q.reponses %}
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" name="reponse_{{ q.id }}" value="{{ r.id }}" id="reponse_{{ q.id }}_{{ r.id }}" required />
                                                    <label class="form-check-label" for="reponse_{{ q.id }}_{{ r.id }}">
                                                        {{ r.contenu }}
                                                    </label>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>

                            <button class="mk-btn-primary" type="submit" style="border:none;padding:10px 22px;">
                                Enregistrer
                            </button>
                        </form>

                    </div>
                </div>

                <div class="mt-3">
                    <a href="{{ path('front_quiz_index') }}" class="text-muted small">← Retour aux tests</a>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}


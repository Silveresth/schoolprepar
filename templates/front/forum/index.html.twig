{% extends 'front/base.html.twig' %}
{% block title %}Forum — SchoolPrepar{% endblock %}

{% block body %}
<section class="mk-hero" style="min-height:32vh;padding:6rem 0 2.5rem;">
    <div class="container">
        <div class="mk-hero-content">
            <span class="mk-badge-pill mb-2 d-inline-block" style="background:rgba(255,255,255,.2);color:#fff;">
                <i class="fas fa-comments me-2"></i>Communauté
            </span>
            <h1>Forum par filière</h1>
            <p>Posez vos questions, partagez vos expériences avec d'autres élèves.</p>
        </div>
    </div>
</section>

<section class="mk-section" style="background:#f8f9fa;">
    <div class="container">
        <div class="row g-4">
            {# Sidebar filtres #}
            <div class="col-lg-3">
                <div class="card border-0 shadow-sm" style="border-radius:16px;position:sticky;top:90px;">
                    <div class="card-body p-3">
                        <h6 class="fw-bold mb-3" style="color:#1a202c;">Filtrer par filière</h6>
                        <a href="{{ path('front_forum_index') }}"
                           class="d-block px-3 py-2 rounded-2 mb-1 text-decoration-none {{ not filtreActif ? 'text-white' : 'text-muted' }}"
                           style="{{ not filtreActif ? 'background:#1A73E8;' : '' }}font-size:.88rem;">
                            Toutes les filières
                        </a>
                        {% for filiere in filieres %}
                        <a href="{{ path('front_forum_index', {'filiere': filiere.nom}) }}"
                           class="d-block px-3 py-2 rounded-2 mb-1 text-decoration-none {{ filtreActif == filiere.nom ? 'text-white' : 'text-muted' }}"
                           style="{{ filtreActif == filiere.nom ? 'background:#1A73E8;' : '' }}font-size:.88rem;">
                            {{ filiere.nom }}
                        </a>
                        {% endfor %}

                        <hr>
                        {% if app.user %}
                        <a href="{{ path('front_forum_new') }}" class="btn btn-primary w-100" style="border-radius:10px;font-size:.88rem;">
                            <i class="fas fa-plus me-1"></i> Nouveau sujet
                        </a>
                        {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-outline-primary w-100" style="border-radius:10px;font-size:.88rem;">
                            🔑 Connectez-vous pour poster
                        </a>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# Liste des sujets #}
            <div class="col-lg-9">
                {% if forums is empty %}
                <div class="text-center py-5 text-muted">
                    <i class="fas fa-comments fa-3x mb-3 d-block opacity-25"></i>
                    Aucun sujet pour le moment.
                    {% if app.user %}<br><a href="{{ path('front_forum_new') }}" class="btn btn-primary btn-sm mt-3">Créer le premier sujet</a>{% endif %}
                </div>
                {% else %}
                <div class="d-flex flex-column gap-3">
                    {% for f in forums %}
                    <a href="{{ path('front_forum_show', {'id': f.id}) }}" class="text-decoration-none">
                        <div class="card border-0 shadow-sm" style="border-radius:14px;transition:transform .15s,box-shadow .15s;" onmouseover="this.style.transform='translateX(4px)';this.style.boxShadow='0 8px 24px rgba(26,115,232,.12)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
                            <div class="card-body p-4 d-flex align-items-start gap-3">
                                <div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,#e8f0fe,#c5d8fc);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1.2rem;">💬</div>
                                <div class="flex-fill" style="min-width:0;">
                                    <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                                        <span style="font-size:.72rem;padding:2px 10px;background:#f0f7ff;color:#1A73E8;border-radius:20px;font-weight:600;">{{ f.filiere.nom }}</span>
                                        <span class="text-muted" style="font-size:.75rem;">{{ f.auteur.nomComplet }}</span>
                                        {% if f.createdAt %}
                                        <span class="text-muted" style="font-size:.72rem;">· {{ f.createdAt|date('d/m/Y') }}</span>
                                        {% endif %}
                                    </div>
                                    <h6 class="fw-bold mb-1" style="color:#1a202c;font-size:.95rem;">{{ f.titre }}</h6>
                                    <p class="text-muted mb-0" style="font-size:.82rem;line-height:1.6;">{{ f.contenu|slice(0,150) }}{% if f.contenu|length > 150 %}…{% endif %}</p>
                                </div>
                                <div class="text-center flex-shrink-0" style="min-width:44px;">
                                    <div class="fw-bold" style="color:#1A73E8;font-size:1.1rem;">{{ f.reponses|length }}</div>
                                    <div class="text-muted" style="font-size:.7rem;">réponse{{ f.reponses|length > 1 ? 's' : '' }}</div>
                                </div>
                            </div>
                        </div>
                    </a>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% extends 'front/base.html.twig' %}
{% block title %}{{ forum.titre }} — Forum SchoolPrepar{% endblock %}

{% block body %}
<section class="mk-hero" style="min-height:26vh;padding:5.5rem 0 2rem;">
    <div class="container">
        <div class="mk-hero-content">
            <span class="mk-badge-pill mb-2 d-inline-block" style="background:rgba(255,255,255,.2);color:#fff;">
                <i class="fas fa-comments me-2"></i>{{ forum.filiere.nom }}
            </span>
            <h1 style="font-size:1.8rem;">{{ forum.titre }}</h1>
        </div>
    </div>
</section>

<section class="mk-section" style="background:#f8f9fa;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                {# Message original #}
                <div class="card border-0 shadow-sm mb-4" style="border-radius:16px;">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#1A73E8,#49a3f1);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:1.1rem;flex-shrink:0;">
                                {{ forum.auteur.prenom[0] }}
                            </div>
                            <div>
                                <div class="fw-bold" style="color:#1a202c;">{{ forum.auteur.nomComplet }}</div>
                                <div class="text-muted" style="font-size:.78rem;">
                                    Auteur · {% if forum.createdAt %}{{ forum.createdAt|date('d/m/Y à H:i') }}{% endif %}
                                </div>
                            </div>
                            <span class="ms-auto" style="font-size:.75rem;padding:4px 12px;background:#f0f7ff;color:#1A73E8;border-radius:20px;font-weight:600;">{{ forum.filiere.nom }}</span>
                        </div>
                        <div style="line-height:1.8;color:#4a5568;white-space:pre-wrap;">{{ forum.contenu }}</div>
                    </div>
                </div>

                {# Réponses #}
                <div id="reponses">
                    <h6 class="fw-bold mb-3" style="color:#1a202c;">
                        💬 {{ forum.reponses|length }} réponse{{ forum.reponses|length > 1 ? 's' : '' }}
                    </h6>

                    {% if forum.reponses|length > 0 %}
                    <div class="d-flex flex-column gap-3 mb-4">
                        {% for reponse in forum.reponses %}
                        <div class="card border-0 shadow-sm" style="border-radius:14px;{% if reponse.auteur.id == (app.user ? app.user.id : 0) %}border-left: 3px solid #1A73E8;{% endif %}">
                            <div class="card-body p-3">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <div style="width:34px;height:34px;border-radius:50%;background:{% if reponse.auteur.id == (app.user ? app.user.id : 0) %}linear-gradient(135deg,#1A73E8,#49a3f1){% else %}linear-gradient(135deg,#667eea,#764ba2){% endif %};display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:.85rem;flex-shrink:0;">
                                        {{ reponse.auteur.prenom[0] }}
                                    </div>
                                    <div>
                                        <span class="fw-semibold" style="font-size:.88rem;color:#1a202c;">{{ reponse.auteur.nomComplet }}</span>
                                        {% if reponse.auteur.id == forum.auteur.id %}
                                        <span style="font-size:.7rem;padding:1px 7px;background:#e8f0fe;color:#1A73E8;border-radius:10px;margin-left:4px;">Auteur</span>
                                        {% endif %}
                                    </div>
                                    <span class="ms-auto text-muted" style="font-size:.73rem;">{{ reponse.createdAt|date('d/m/Y H:i') }}</span>
                                </div>
                                <div style="font-size:.88rem;color:#4a5568;line-height:1.7;padding-left:44px;white-space:pre-wrap;">{{ reponse.contenu }}</div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <div class="text-center py-4 text-muted mb-4" style="font-size:.9rem;">
                        Aucune réponse pour l'instant. Soyez le premier à répondre !
                    </div>
                    {% endif %}

                    {# Formulaire réponse #}
                    {% if app.user %}
                    <div class="card border-0 shadow-sm" style="border-radius:16px;">
                        <div class="card-header bg-white border-0 pt-3 pb-0 px-4">
                            <h6 class="fw-bold mb-0" style="color:#1a202c;">✍️ Votre réponse</h6>
                        </div>
                        <div class="card-body p-4">
                            {{ form_start(form) }}
                            {{ form_widget(form.contenu, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Partagez votre réponse ou votre expérience…', 'style': 'border-radius:10px;border:1.5px solid #e2e8f0;'}}) }}
                            {{ form_errors(form.contenu) }}
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="text-muted" style="font-size:.8rem;">Vous répondez en tant que <strong>{{ app.user.nomComplet }}</strong></span>
                                <button type="submit" class="btn btn-primary" style="border-radius:10px;font-size:.88rem;padding:.5rem 1.5rem;">
                                    <i class="fas fa-paper-plane me-1"></i> Publier
                                </button>
                            </div>
                            {{ form_end(form) }}
                        </div>
                    </div>
                    {% else %}
                    <div class="alert" style="border-radius:12px;background:#f0f7ff;border:1px solid #c5d8fc;color:#1A73E8;text-align:center;">
                        <a href="{{ path('app_login') }}" style="color:#1A73E8;font-weight:600;">Connectez-vous</a> pour répondre à ce sujet.
                    </div>
                    {% endif %}
                </div>

                <div class="mt-4">
                    <a href="{{ path('front_forum_index') }}" class="text-muted small">← Retour au forum</a>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% extends 'front/base.html.twig' %}
{% block title %}Conversation avec {{ dest.nomComplet }} — SchoolPrepar{% endblock %}

{% block body %}
<section class="mk-hero" style="min-height:28vh;padding:6rem 0 2.5rem;">
    <div class="container">
        <div class="mk-hero-content">
            <span class="mk-badge-pill mb-2 d-inline-block" style="background:rgba(255,255,255,.2);color:#fff;">
                <i class="fas fa-paper-plane me-2"></i>Messagerie privée
            </span>
            <h1>{{ dest.nomComplet }}</h1>
            {% if mentorProfile %}
                <p class="text-white" style="opacity:.85;">
                    🧑‍🏫 Conseiller — {{ mentorProfile.specialite }}
                </p>
            {% else %}
                <p class="text-white" style="opacity:.85;">{{ dest.email }}</p>
            {% endif %}
        </div>
    </div>
</section>

<section class="mk-section" style="background:#f8f9fa;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                {# Carte profil du conseiller #}
                {% if mentorProfile %}
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body d-flex align-items-center gap-3 p-3">
                        <div style="width:50px;height:50px;border-radius:50%;background:linear-gradient(135deg,#49a3f1,#1A73E8);display:flex;align-items:center;justify-content:center;font-size:1.5rem;color:#fff;flex-shrink:0;">
                            🧑‍🏫
                        </div>
                        <div class="flex-fill">
                            <div class="fw-bold">{{ dest.nomComplet }}</div>
                            <div class="text-muted small">{{ mentorProfile.specialite }} · {{ mentorProfile.tarif|number_format(0,',',' ') }} FCFA/h</div>
                        </div>
                        <a href="{{ path('front_mentor_show', {'id': mentorProfile.id}) }}"
                           class="btn btn-sm btn-outline-primary">Voir le profil</a>
                    </div>
                </div>
                {% endif %}

                {# Zone messages #}
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom d-flex align-items-center justify-content-between py-3">
                        <h5 class="mb-0">💬 Conversation</h5>
                        <span class="badge bg-secondary">{{ messages|length }} message{{ messages|length > 1 ? 's' : '' }}</span>
                    </div>
                    <div class="card-body p-4" style="max-height:420px;overflow-y:auto;" id="chatBox">
                        {% if messages|length > 0 %}
                            <div class="d-flex flex-column gap-3">
                                {% for m in messages %}
                                    <div class="d-flex {% if m.expediteur.id == app.user.id %}justify-content-end{% endif %}">
                                        <div class="p-3 rounded-3 {% if m.expediteur.id == app.user.id %}bg-primary text-white{% else %}bg-light{% endif %}"
                                             style="max-width:75%;">
                                            <div class="small fw-semibold mb-1" style="opacity:.8;">
                                                {% if m.expediteur.id == app.user.id %}Moi{% else %}{{ m.expediteur.nomComplet }}{% endif %}
                                            </div>
                                            <div style="white-space:pre-wrap;line-height:1.5;">{{ m.contenu }}</div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="text-center py-5 text-muted">
                                <i class="fas fa-comment-slash fa-2x mb-3 d-block opacity-25"></i>
                                Commencez la conversation en envoyant votre premier message.
                            </div>
                        {% endif %}
                    </div>
                    <div class="card-footer bg-white border-top p-4">
                        {{ form_start(form) }}
                        <div class="d-flex gap-2 align-items-end">
                            <div class="flex-fill">
                                {{ form_widget(form.contenu, {
                                    'attr': {
                                        'class': 'form-control',
                                        'rows': 2,
                                        'placeholder': 'Écrivez votre message…'
                                    }
                                }) }}
                                {{ form_errors(form.contenu) }}
                            </div>
                            <button type="submit" class="btn btn-primary px-4" style="height:fit-content;">
                                ➤ Envoyer
                            </button>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>

                <div class="mt-3">
                    <a href="{{ path('front_chat_index') }}" class="text-muted small">← Retour à la messagerie</a>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    // Scroll automatique vers le bas du chat
    const chatBox = document.getElementById('chatBox');
    if (chatBox) chatBox.scrollTop = chatBox.scrollHeight;
</script>
{% endblock %}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}SchoolPrepar{% endblock %}</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700,900|Roboto+Slab:400,700">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('css/custom.css') }}">
    <style>
        :root {
            --mk-primary: #1A73E8;
            --mk-secondary: #344767;
            --mk-gradient: linear-gradient(195deg, #42424a, #191919);
            --mk-gradient-blue: linear-gradient(195deg, #49a3f1, #1A73E8);
            --mk-shadow-blue: 0 4px 20px 0 rgba(0,0,0,.14),0 7px 10px -5px rgba(26,115,232,.4);
        }
        body { font-family: 'Roboto', sans-serif; color: #344767; }
        .mk-navbar {
            position: fixed; top: 1rem; left: 50%; transform: translateX(-50%);
            width: calc(100% - 2rem); max-width: 1200px;
            background: rgba(255,255,255,0.95); backdrop-filter: saturate(200%) blur(30px);
            border-radius: 12px; padding: .75rem 1.5rem;
            box-shadow: 0 2px 12px rgba(0,0,0,.1); z-index: 1000;
            display: flex; align-items: center; justify-content: center; gap: 1rem;
        }
        /* centrer le contenu quand la largeur change */
        .mk-navbar > .d-flex.align-items-center.gap-2,
        .mk-navbar > .mk-nav-links {
            display: flex;
            align-items: center;
        }
        .mk-navbar .mk-nav-links{ justify-content:center; }

        .mk-navbar-brand { font-size: 1.1rem; font-weight: 700; color: var(--mk-secondary); text-decoration: none; white-space: nowrap; }
        .mk-navbar-brand span { color: var(--mk-primary); }
        .mk-nav-links { display: flex; align-items: center; gap: 1.5rem; list-style: none; margin: 0; padding: 0; flex-grow: 1; }
        .mk-nav-links a { color: var(--mk-secondary); text-decoration: none; font-size: .875rem; font-weight: 500; transition: color .2s; }
        .mk-nav-links a:hover, .mk-nav-links a.active { color: var(--mk-primary); }

        /* Dropdown menu (pour matcher ton template, sans être “caché” par bootstrap theme) */
        .mk-dropdown-menu{
            background: #191919 !important;
            border: 1px solid rgba(255,255,255,.12);
            border-radius: 10px;
            padding: .35rem 0;
            overflow: hidden;
        }
        .mk-dropdown-menu .dropdown-item{
            color: rgba(255,255,255,.85) !important;
            font-weight: 600;
            padding: .55rem 1rem;
        }
        .mk-dropdown-menu .dropdown-item:hover,
        .mk-dropdown-menu .dropdown-item:focus{
            background: rgba(26,115,232,.18) !important;
            color: #fff !important;
        }

        .mk-btn-nav { background: var(--mk-gradient-blue); color: #fff !important; padding: 8px 20px; border-radius: 8px; font-size: .8rem !important; font-weight: 700 !important; box-shadow: var(--mk-shadow-blue); text-decoration: none; transition: transform .2s; white-space: nowrap; }
        .mk-btn-nav:hover { transform: translateY(-1px); opacity:.9; }
        .mk-btn-nav-outline { border: 2px solid var(--mk-primary); color: var(--mk-primary) !important; padding: 6px 18px; border-radius: 8px; font-size: .8rem !important; font-weight: 700 !important; text-decoration: none; transition: all .2s; white-space: nowrap; }
        .mk-btn-nav-outline:hover { background: var(--mk-primary); color: #fff !important; }
        /* Hero */
        .mk-hero { min-height: 75vh; display: flex; align-items: center; background: var(--mk-gradient); padding: 8rem 0 4rem; position: relative; overflow: hidden; }
        .mk-hero::before { content: ''; position: absolute; inset: 0; background: url('https://images.unsplash.com/photo-1523050854058-8df90110c9f1?w=1400&q=80') center/cover; opacity: .3; }
        .mk-hero-content { position: relative; z-index: 1; color: #fff; }
        .mk-hero h1 { font-size: clamp(2rem,5vw,3.5rem); font-weight: 700; line-height: 1.2; margin-bottom: 1rem; }
        .mk-hero p { font-size: 1.1rem; opacity: .85; margin-bottom: 2rem; }
        .mk-btn-primary { background: var(--mk-gradient-blue); color: #fff; border: none; padding: 12px 32px; border-radius: 8px; font-weight: 700; font-size: .875rem; box-shadow: var(--mk-shadow-blue); text-decoration: none; display: inline-flex; align-items: center; gap: 8px; transition: transform .3s, box-shadow .3s; }
        .mk-btn-primary:hover { color: #fff; transform: translateY(-2px); box-shadow: 0 8px 30px rgba(26,115,232,.6); }
        .mk-btn-outline { background: transparent; color: #fff; border: 2px solid rgba(255,255,255,.5); padding: 12px 32px; border-radius: 8px; font-weight: 700; font-size: .875rem; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; transition: all .3s; }
        .mk-btn-outline:hover { background: rgba(255,255,255,.15); color: #fff; border-color: #fff; }
        /* Cards */
        .mk-card { border: none; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,.1); transition: box-shadow .3s, transform .3s; overflow: hidden; }
        .mk-card:hover { box-shadow: 0 8px 30px rgba(0,0,0,.15); transform: translateY(-4px); }
        .mk-card-icon { width: 56px; height: 56px; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; color: #fff; font-size: 1.5rem; box-shadow: var(--mk-shadow-blue); }
        .bg-gradient-primary { background: var(--mk-gradient-blue); }
        .bg-gradient-success { background: linear-gradient(195deg,#66BB6A,#43A047); }
        .bg-gradient-dark    { background: var(--mk-gradient); }
        .bg-gradient-warning { background: linear-gradient(195deg,#FFA726,#FB8C00); }
        .mk-section { padding: 5rem 0; }
        .mk-section-title { font-size: 2rem; font-weight: 700; color: var(--mk-secondary); margin-bottom: .5rem; }
        .mk-section-subtitle { color: #7b809a; font-size: 1rem; margin-bottom: 3rem; }
        .mk-badge-pill { display: inline-block; padding: 4px 14px; border-radius: 50px; font-size: .75rem; font-weight: 600; background: #e3f2fd; color: var(--mk-primary); }
        /* Footer */
        .mk-footer { background: var(--mk-gradient); color: rgba(255,255,255,.8); padding: 4rem 0 2rem; }
        .mk-footer h6 { color: #fff; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; font-size: .8rem; margin-bottom: 1rem; }
        .mk-footer a { color: rgba(255,255,255,.7); text-decoration: none; font-size: .875rem; line-height: 2; }
        .mk-footer a:hover { color: #fff; }
        .mk-footer-bottom { border-top: 1px solid rgba(255,255,255,.2); margin-top: 2rem; padding-top: 1.5rem; font-size: .8rem; }
        .mk-page-content { padding-top: 80px; }
        /* Alertes flash */
        .flash-zone { position: fixed; top: 5rem; right: 1rem; z-index: 2000; min-width: 320px; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

{# ── NAVBAR ── #}
<nav class="mk-navbar">
    <a class="mk-navbar-brand" href="{{ path('home') }}">🎓 School<span>Prepar</span></a>

    <ul class="mk-nav-links d-none d-lg-flex">
        {# Navigation “utile” visible (raccourcie) #}
        <li><a href="{{ path('home') }}" class="{{ app.request.get('_route') == 'home' ? 'active' : '' }}">Accueil</a></li>
        <li><a href="{{ path('filiere') }}" class="{{ app.request.get('_route') starts with 'filiere' ? 'active' : '' }}">Filières</a></li>
        <li><a href="{{ path('etablissement') }}" class="{{ app.request.get('_route') starts with 'etablissement' ? 'active' : '' }}">Établissements</a></li>

        {# Reste des modules dans un menu dropdown #}
        <li class="dropdown">
            <a class="dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                Plus
            </a>
            <ul class="dropdown-menu mk-dropdown-menu">
                <li><a class="dropdown-item" href="{{ path('front_recommandations_index') }}">Recommandations</a></li>
                <li><a class="dropdown-item" href="{{ path('front_quiz_index') }}">Quiz</a></li>
                <li><a class="dropdown-item" href="{{ path('front_forum_index') }}">Forum</a></li>
                <li><a class="dropdown-item" href="{{ path('front_chat_index') }}">Chat</a></li>
                <li><a class="dropdown-item" href="{{ path('front_webinaires_index') }}">Webinaires</a></li>
                {% if is_granted('ROLE_MENTOR') %}
                    <li><a class="dropdown-item" href="{{ path('front_mentor_index') }}">Mentors (gérer)</a></li>
                {% else %}
                    <li><a class="dropdown-item" href="{{ path('front_mentor_index') }}">Mentors</a></li>
                {% endif %}
                <li><hr class="dropdown-divider"/></li>
                <li><a class="dropdown-item" href="{{ path('front_evenement_index') }}">Événements</a></li>
            </ul>
        </li>
    </ul>



    <div class="d-flex align-items-center gap-2">
        {% if app.user %}
            {# Utilisateur connecté #}
            <div class="dropdown">
                <button class="mk-btn-nav-outline dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    👤 {{ app.user.prenom }}
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow">
                    <li class="px-3 py-2">
                        <div class="fw-bold" style="font-size:.9rem;">{{ app.user.nomComplet }}</div>
                        <div class="text-muted" style="font-size:.78rem;">{{ app.user.email }}</div>
                    </li>
                    <li><hr class="dropdown-divider my-1"></li>
                    {% if is_granted('ROLE_ADMIN') %}
                        <li><a class="dropdown-item" href="{{ path('admin_dashboard') }}">🔧 Administration</a></li>
                    {% elseif is_granted('ROLE_CONSEILLER') or is_granted('ROLE_MENTOR') %}
                        <li><a class="dropdown-item" href="{{ path('mentor_dashboard') }}">📊 Mon tableau de bord</a></li>
                        <li><a class="dropdown-item" href="{{ path('front_profile_mentor_edit') }}">✏️ Mon profil conseiller</a></li>
                    {% else %}
                        <li><a class="dropdown-item" href="{{ path('student_dashboard') }}">📊 Mon tableau de bord</a></li>
                    {% endif %}
                    <li><a class="dropdown-item" href="{{ path('front_profile_index') }}">👤 Mon compte</a></li>
                    <li><a class="dropdown-item" href="{{ path('front_profile_edit') }}">✏️ Modifier mon profil</a></li>
                    <li><hr class="dropdown-divider my-1"></li>
                    <li>
                        <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                            <i class="fas fa-sign-out-alt me-1"></i> Déconnexion
                        </a>
                    </li>
                </ul>
            </div>
        {% else %}
            {# Non connecté #}
            <a href="{{ path('app_login') }}" class="mk-btn-nav-outline">Connexion</a>
            <a href="{{ path('app_register') }}" class="mk-btn-nav">S'inscrire</a>
        {% endif %}
    </div>
</nav>

{# ── ALERTES FLASH ── #}
<div class="flash-zone">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show shadow" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}
</div>

<div class="mk-page-content">
    {% block body %}{% endblock %}
</div>

<footer class="mk-footer">
    <div class="container">
        <div class="row">
            <div class="col-md-4 mb-4">
                <h6>🎓 SchoolPrepar</h6>
                <p style="font-size:.875rem;opacity:.8;line-height:1.8;">La plateforme qui aide les jeunes togolais à choisir leur filière et établissement en toute confiance.</p>
            </div>
            <div class="col-md-3 mb-4">
                <h6>Navigation</h6>
                <div class="d-flex flex-column">
                    <a href="{{ path('home') }}">Accueil</a>
                    <a href="{{ path('filiere') }}">Filières</a>
                    <a href="{{ path('etablissement') }}">Établissements</a>
                    <a href="{{ path('front_evenement_index') }}">Événements</a>
                    <a href="{{ path('front_recommandations_index') }}">Recommandations</a>
                    <a href="{{ path('front_quiz_index') }}">Quiz</a>
                    <a href="{{ path('front_forum_index') }}">Forum</a>
                    <a href="{{ path('front_chat_index') }}">Chat</a>
                    <a href="{{ path('front_webinaires_index') }}">Webinaires</a>
                    <a href="{{ path('front_mentor_index') }}">Mentors</a>

                </div>
            </div>
            <div class="col-md-3 mb-4">
                <h6>Mon compte</h6>
                <div class="d-flex flex-column">
                    {% if app.user %}
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('admin_dashboard') }}">Administration</a>
                        {% endif %}
                        <a href="{{ path('app_logout') }}" class="text-danger mt-1">Déconnexion</a>
                    {% else %}
                        <a href="{{ path('app_login') }}">Connexion</a>
                        <a href="{{ path('app_register') }}">S'inscrire</a>
                    {% endif %}
                </div>
            </div>
            <div class="col-md-2 mb-4">
                <h6>Contact</h6>
                <p style="font-size:.875rem;opacity:.8;">IPNET Institute<br>Lomé, Togo</p>
            </div>
        </div>
        <div class="mk-footer-bottom d-flex justify-content-between flex-wrap gap-2">
            <span>© {{ "now"|date("Y") }} SchoolPrepar — Tous droits réservés</span>
            <span>Symfony & TP4</span>
        </div>
    </div>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>

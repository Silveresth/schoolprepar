{% extends 'front/base.html.twig' %}
{% block title %}Modifier mon profil — SchoolPrepar{% endblock %}

{% block body %}
<section class="mk-hero" style="min-height:26vh;padding:5.5rem 0 2rem;">
    <div class="container">
        <div class="mk-hero-content">
            <h1>✏️ Modifier mon profil</h1>
            <p>Mettez à jour vos informations personnelles.</p>
        </div>
    </div>
</section>

<section class="mk-section" style="background:#f8f9fa;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card border-0 shadow-sm" style="border-radius:16px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Informations personnelles</h5>
                        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label class="form-label fw-semibold" style="font-size:.85rem;">Prénom</label>
                                {{ form_widget(form.prenom, {'attr': {'class': 'form-control', 'style': 'border-radius:10px;'}}) }}
                                {{ form_errors(form.prenom) }}
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-semibold" style="font-size:.85rem;">Nom</label>
                                {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'style': 'border-radius:10px;'}}) }}
                                {{ form_errors(form.nom) }}
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold" style="font-size:.85rem;">Email</label>
                            {{ form_widget(form.email, {'attr': {'class': 'form-control', 'style': 'border-radius:10px;'}}) }}
                            {{ form_errors(form.email) }}
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-primary flex-fill" style="border-radius:10px;">
                                💾 Enregistrer
                            </button>
                            <a href="{{ path('front_profile_index') }}" class="btn btn-outline-secondary" style="border-radius:10px;">
                                Annuler
                            </a>
                        </div>

                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

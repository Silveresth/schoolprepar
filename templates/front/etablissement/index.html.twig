{% extends 'front/base.html.twig' %}
{% block title %}Établissements - SchoolPrepar{% endblock %}

{% block body %}

<div style="background:linear-gradient(195deg,#42424a,#191919);padding:7rem 0 4rem;color:#fff;">
    <div class="container">
        <p class="text-uppercase fw-bold small mb-2" style="color:#49a3f1;letter-spacing:2px;">Découvrir</p>
        <h1 class="fw-bold mb-3" style="font-size:2.5rem;">Nos établissements</h1>
        <p style="opacity:.8;">Explorez les établissements partenaires et leurs filières proposées.</p>
    </div>
</div>

<section class="mk-section" style="background:#f8f9fa;">
    <div class="container">

        {% if etablissements is empty %}
        <div class="text-center py-5">
            <i class="fas fa-university fa-3x text-muted mb-3"></i>
            <p class="text-muted">Aucun établissement disponible pour le moment.</p>
            <a href="{{ path('home') }}" class="mk-btn-primary">Retour à l'accueil</a>
        </div>
        {% else %}
        <div class="row mb-4">
            <div class="col">
                <h5 class="fw-bold mb-0" style="color:#344767;">{{ etablissements|length }} établissement{{ etablissements|length > 1 ? 's' : '' }}</h5>
            </div>
        </div>

        <div class="row g-4">
            {% for etab in etablissements %}
            <div class="col-md-6 col-lg-4">
                <div class="mk-card card h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <div class="mk-card-icon bg-gradient-success mb-0 flex-shrink-0" style="width:48px;height:48px;">
                                <i class="fas fa-university" style="font-size:1.1rem;"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1" style="color:#344767;">{{ etab.nom }}</h6>
                                <small class="text-muted">
                                    <i class="fas fa-map-marker-alt me-1" style="color:#43A047;"></i>
                                    {{ etab.ville }}
                                </small>
                            </div>
                        </div>
                        <p class="text-muted small mb-3">
                            <i class="fas fa-map-signs me-1"></i> {{ etab.adresse }}
                        </p>
                        {% if etab.filieres|length > 0 %}
                        <hr class="my-3" style="border-color:#f0f0f0;">
                        <p class="small fw-bold mb-2" style="color:#344767;">
                            <i class="fas fa-book me-1" style="color:#1A73E8;"></i>
                            {{ etab.filieres|length }} filière{{ etab.filieres|length > 1 ? 's' : '' }} :
                        </p>
                        <div class="d-flex flex-wrap gap-1">
                            {% for f in etab.filieres|slice(0,3) %}
                                <span class="mk-badge-pill">{{ f.nom }}</span>
                            {% endfor %}
                            {% if etab.filieres|length > 3 %}
                                <span class="mk-badge-pill" style="background:#f0f0f0;color:#7b809a;">+{{ etab.filieres|length - 3 }}</span>
                            {% endif %}
                        </div>
                        {% else %}
                        <p class="text-muted small mb-0"><em>Aucune filière référencée</em></p>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

    </div>
</section>

{% endblock %}

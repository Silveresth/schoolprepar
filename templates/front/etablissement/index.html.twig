{% extends 'front/base.html.twig' %}
{% block title %}Établissements — SchoolPrepar{% endblock %}

{% block body %}
<section class="mk-hero" style="min-height:40vh;padding:7rem 0 3rem;">
    <div class="container">
        <div class="mk-hero-content">
            <h1>🏫 Établissements partenaires</h1>
            <p>Découvrez les établissements disponibles au Togo</p>
        </div>
    </div>
</section>

<section class="mk-section" style="background:#f8f9fa;">
    <div class="container">
        <div class="row g-4">
            {% for etablissement in etablissements %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0" style="border-radius:16px;box-shadow:0 4px 20px rgba(0,0,0,.07);transition:transform .2s,box-shadow .2s;overflow:hidden;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 12px 32px rgba(26,115,232,.15)'" onmouseout="this.style.transform='';this.style.boxShadow='0 4px 20px rgba(0,0,0,.07)'">
                    <div style="height:5px;background:linear-gradient(90deg,#43a047,#66bb6a);"></div>
                    <div class="card-body p-4">
                        {% set img = etablissement.imageFilename %}
                        <div style="width:100%;height:120px;border-radius:18px;overflow:hidden;background:#fff;flex-shrink:0;border:2px solid rgba(67,160,71,.15);margin-bottom:14px;">
                            <img
                                src="{{ img ? asset('img/photos/' ~ img) : asset('img/photos/unsplash-1.jpg') }}"
                                alt="Image établissement"
                                style="width:100%;height:100%;object-fit:cover;"
                            />
                        </div>

                        <div>
                            <h6 class="fw-bold mb-1" style="color:#1a202c;font-size:.95rem;">{{ etablissement.nom }}</h6>
                            <div class="text-muted" style="font-size:.78rem;"><i class="fas fa-city fa-xs me-1"></i>{{ etablissement.ville }}</div>
                            <div class="text-muted" style="font-size:.75rem;"><i class="fas fa-map-marker-alt fa-xs me-1"></i>{{ etablissement.adresse }}</div>
                        </div>
                        {% if etablissement.filieres is defined and etablissement.filieres|length > 0 %}
                        <div class="mb-3 p-2 rounded-2" style="background:#f1f8f1;font-size:.8rem;color:#2e7d32;font-weight:500;">
                            <i class="fas fa-layer-group me-1"></i>{{ etablissement.filieres|length }} filière{{ etablissement.filieres|length > 1 ? 's' : '' }} disponible{{ etablissement.filieres|length > 1 ? 's' : '' }}
                        </div>
                        {% endif %}
                        <a href="{{ path('front_etablissement_details_show', {'id': etablissement.id}) }}" class="btn btn-sm w-100" style="background:linear-gradient(135deg,#43a047,#66bb6a);color:#fff;border:none;border-radius:8px;font-size:.8rem;">Voir les détails</a>
                    </div>
                </div>
            </div>
            {% else %}

            <div class="col-12 text-center py-5 text-muted">
                <i class="fas fa-inbox fa-3x mb-3 d-block opacity-25"></i>
                Aucun établissement disponible pour le moment.
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="{{ path('home') }}">🎓 SchoolPrepar</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link {{ app.request.get('_route') == 'home' ? 'active' : '' }}"
                       href="{{ path('home') }}">Accueil</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ app.request.get('_route') starts with 'filiere' ? 'active' : '' }}"
                       href="{{ path('filiere') }}">Filières</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ app.request.get('_route') starts with 'etablissement' ? 'active' : '' }}"
                       href="{{ path('etablissement') }}">Établissements</a>
                </li>
                {% if app.user %}
                <li class="nav-item">
                    <a class="nav-link {{ app.request.get('_route') starts with 'front_mentor' ? 'active' : '' }}"
                       href="{{ path('front_mentor_index') }}">Mentors</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ app.request.get('_route') starts with 'front_evenement' ? 'active' : '' }}"
                       href="{{ path('front_evenement_index') }}">Événements</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link {{ app.request.get('_route') starts with 'front_forum' ? 'active' : '' }}"
                       href="{{ path('front_forum_index') }}">Forum</a>
                </li>
                {% endif %}
            </ul>

            <ul class="navbar-nav ms-auto">
                {% if app.user %}
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.get('_route') starts with 'front_chat' ? 'active' : '' }}"
                           href="{{ path('front_chat_index') }}">
                            💬 Messages
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            👤 {{ app.user.nomComplet }}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            {# Lien dashboard selon le rôle #}
                            {% if is_granted('ROLE_ADMIN') %}
                                <li>
                                    <a class="dropdown-item" href="{{ path('admin_dashboard') }}">
                                        🔧 Panel Admin
                                    </a>
                                </li>
                            {% else %}
                                {% if is_granted('ROLE_CONSEILLER') or is_granted('ROLE_MENTOR') %}
                                    {% set dashboardRoute = 'mentor_dashboard' %}
                                {% else %}
                                    {% set dashboardRoute = 'student_dashboard' %}
                                {% endif %}
                                <li>
                                    <a class="dropdown-item" href="{{ path(dashboardRoute) }}">
                                        📊 Mon tableau de bord
                                    </a>
                                </li>
                            {% endif %}
                            <li><a class="dropdown-item" href="{{ path('front_profile_index') }}">👤 Mon profil</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                    🚪 Déconnexion
                                </a>
                            </li>
                        </ul>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_login') }}">🔑 Connexion</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-primary btn-sm ms-2 nav-link" href="{{ path('app_register') }}">
                            ✍️ S'inscrire
                        </a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>
